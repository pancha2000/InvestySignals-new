# ============================================================
#  InvestySignals — Environment Variables
#  Copy this file to .env and fill in your values:
#  cp .env.example .env && nano .env
# ============================================================

# MongoDB connection string (local default)
MONGO_URI=mongodb://127.0.0.1:27017/investysignals

# Groq AI API key — get from https://console.groq.com
GROQ_API_KEY=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

# App port (default 3000 — don't change if using Nginx)
PORT=2000

# Your domain or VPS IP (used for CORS)
# Examples:
#   https://investysignals.com
#   https://www.investysignals.com
#   http://123.456.789.0   (IP only, no SSL)
ALLOWED_ORIGIN=https://investysignals.store

