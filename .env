# ============================================================
#  InvestySignals — Environment Variables
#  VPS හි /var/www/investysignals/.env ලෙස save කරන්න
# ============================================================

# Server Port
PORT=3000

# MongoDB Connection
# VPS local MongoDB (auth enabled recommended):
MONGO_URI=mongodb://127.0.0.1:27017/investysignals

# MongoDB Atlas (cloud) use කරන්නේ නම් uncomment:
# MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/investysignals?retryWrites=true&w=majority

# Node Environment
NODE_ENV=production

# FIX #8: ALLOWED_ORIGIN — ඔබේ domain දමන්න (wildcard වළකින්න)
# Example: ALLOWED_ORIGIN=https://investysignals.com
ALLOWED_ORIGIN=https://yourdomain.com

# ai api

GEMINI_API_KEY=AIzaSyAvzBB554PkLOhacw-JEd15Yqsg8E1f_Ec
