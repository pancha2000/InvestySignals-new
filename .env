# ============================================================
#  InvestySignals — Environment Variables
#  VPS හි /var/www/investysignals/.env ලෙස save කරන්න
# ============================================================

# Server Port
PORT=3000

# MongoDB Connection
# VPS local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/investysignals

# MongoDB Atlas (cloud) use කරන්නේ නම් uncomment:
# MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/investysignals?retryWrites=true&w=majority

# Node Environment
NODE_ENV=production
