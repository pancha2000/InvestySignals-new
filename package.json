{
  "name": "investysignals-sigma-agent",
  "version": "4.1.0",
  "description": "InvestySignals — SIGMA AI Agent v2.1 (Full Merged)",
  "main": "server.js",
  "scripts": {
    "start":         "node server.js",
    "dev":           "nodemon server.js",
    "pm2:start":     "pm2 start server.js --name investysignals --restart-delay=3000 --max-memory-restart 512M",
    "pm2:stop":      "pm2 stop investysignals",
    "pm2:restart":   "pm2 restart investysignals",
    "pm2:reload":    "pm2 reload investysignals",
    "pm2:logs":      "pm2 logs investysignals",
    "pm2:status":    "pm2 status"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@langchain/core":       "^0.3.20",
    "@langchain/groq":       "^0.1.3",
    "langchain":             "^0.3.6",
    "zod":                   "^3.23.8",
    "express":               "^4.19.2",
    "cors":                  "^2.8.5",
    "helmet":                "^7.1.0",
    "express-rate-limit":    "^7.3.1",
    "dotenv":                "^16.4.5",
    "node-cache":            "^5.1.2",
    "mongoose":              "^8.4.1",
    "firebase-admin":        "^12.2.0",
    "ws":                    "^8.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
